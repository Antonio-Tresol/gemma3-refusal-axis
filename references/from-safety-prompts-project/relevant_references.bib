% ---- Primary methodology sources ----

@article{lu2026assistant,
  title     = {The Assistant Axis: Situating and Stabilizing the Default Persona of Language Models},
  author    = {Lu, Christina and Gallagher, Jack and Michala, Jonathan and Fish, Kyle and Lindsey, Jack},
  journal   = {arXiv preprint arXiv:2601.10387},
  year      = {2026},
  url       = {https://arxiv.org/abs/2601.10387},
  note      = {Introduces the Assistant Axis --- a single direction separating default assistant from role-playing personas. Activation capping along this axis prevents jailbreaks. Our refusal axis methodology extends their Sec~3.1 formula and Sec~4.2 capping calibration.},
}

@inproceedings{arditi2024refusal,
  title     = {Refusal in Language Models Is Mediated by a Single Direction},
  author    = {Arditi, Andy and Obeso, Oscar and Syed, Aaquib and Paleka, Daniel and Panickssery, Nina and Gurnee, Wes and Nanda, Neel},
  booktitle = {Advances in Neural Information Processing Systems (NeurIPS)},
  year      = {2024},
  url       = {https://arxiv.org/abs/2406.11717},
  note      = {Demonstrates refusal is mediated by a one-dimensional subspace across 13 open-source chat models up to 72B parameters. We build on their contrastive direction extraction and last-prompt-token extraction site.},
}

@article{chen2025persona,
  title     = {Persona Vectors: Monitoring and Controlling Character Traits in Language Models},
  author    = {Chen, Runjin and others},
  journal   = {arXiv preprint arXiv:2507.21509},
  year      = {2025},
  url       = {https://arxiv.org/abs/2507.21509},
  note      = {Sec~2.2: trait expression scoring and mean-response-token extraction. Appendix~M: decomposes ``evil'' persona vector into granular SAE features (e.g., ``insulting language'' feature 12061, ``malicious code'' feature 14739). We follow their trait scoring methodology and decoder-cosine decomposition.},
}

@article{joad2026refusal,
  title     = {There Is More to Refusal in Large Language Models than a Single Direction},
  author    = {Joad, Faaiz and Hawasly, Majd and Boughorbel, Sabri and Durrani, Nadir and Sencar, Husrev Taha},
  journal   = {arXiv preprint arXiv:2602.02132},
  year      = {2026},
  url       = {https://arxiv.org/abs/2602.02132},
  note      = {Finds geometrically distinct refusal directions across 11 categories, but steering along any refusal-related direction produces nearly identical trade-offs --- a ``shared one-dimensional control knob.'' Our domain-selective capping tests whether independent control is possible.},
}

% ---- SAE methodology sources ----

@article{wang2025sails,
  title     = {Interpretable Safety Alignment via {SAE}-Constructed Low-Rank Subspace Adaptation},
  author    = {Wang, Dianyun and others},
  journal   = {arXiv preprint arXiv:2512.23260},
  year      = {2025},
  url       = {https://arxiv.org/abs/2512.23260},
  note      = {SAILS. Stage~1 proves SAE-based contrastive identification avoids the irreducible error floor of direct subspace recovery. Identifies refusal features at 16k width but does not examine larger widths or geometric directions per domain.},
}

@article{bricken2023monosemanticity,
  title     = {Towards Monosemanticity: Decomposing Language Models With Dictionary Learning},
  author    = {Bricken, Trenton and Templeton, Adly and Batson, Joshua and Chen, Brian and Jermyn, Adam and Conerly, Tom and Turner, Nick and Anil, Cem and Denison, Carson and Askell, Amanda and Lasenby, Robert and Wu, Yifan and Kravec, Shauna and Schiefer, Nicholas and Maxwell, Tim and Joseph, Nicholas and Hatfield-Dodds, Zac and Henighan, Tom and March, Scott and Bowman, Sam and Tabor, Samuel and Caballero, Ethan and Olah, Chris},
  journal   = {Transformer Circuits Thread},
  publisher = {Anthropic},
  year      = {2023},
  url       = {https://transformer-circuits.pub/2023/monosemantic-features/index.html},
  note      = {Introduces dictionary learning with sparse autoencoders for mechanistic interpretability. Establishes decoder cosine similarity as a method for identifying feature splitting. We use their decoder cosine approach for hierarchy analysis (Method~1).},
}

@article{bussmann2025matryoshka,
  title     = {Learning Multi-Level Features with Matryoshka Sparse Autoencoders},
  author    = {Bussmann, Bart and others},
  journal   = {arXiv preprint arXiv:2503.17547},
  year      = {2025},
  url       = {https://arxiv.org/abs/2503.17547},
  note      = {Validates hierarchies via decoder geometry with explicit cosine thresholds. We use their decoder cosine threshold methodology for hierarchy analysis (Method~1).},
}

@article{chanin2024absorption,
  title     = {A is for Absorption: Studying Feature Splitting and Absorption in Sparse Autoencoders},
  author    = {Chanin, David and others},
  journal   = {arXiv preprint arXiv:2409.14507},
  year      = {2024},
  url       = {https://arxiv.org/abs/2409.14507},
  note      = {Studies feature absorption --- parent features failing to fire when absorbed into children. Introduces absorption detection metrics. We use co-activation analysis (Method~2) to distinguish absorption from splitting, following their framework.},
}

@article{luo2026hsae,
  title     = {From Atoms to Trees: Building a Structured Feature Forest with Hierarchical Sparse Autoencoders},
  author    = {Luo, Yifan and Zhan, Yang and Jiang, Jiedong and Liu, Tianyang and Wu, Mingrui and Zhou, Zhennan and Dong, Bin},
  journal   = {arXiv preprint arXiv:2602.11881},
  year      = {2026},
  url       = {https://arxiv.org/abs/2602.11881},
  note      = {HSAE. Sec~3.2: structural constraint loss encourages parent-child decoder alignment. We apply their R-squared evaluation metric (Method~3) --- fitting a parent's decoder vector as a weighted combination of children's decoder vectors.},
}

