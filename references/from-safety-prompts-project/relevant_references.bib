% --- Refusal directions / category-specific steering ---

@article{alagharu2026categorical,
  title   = {From Refusal Tokens to Refusal Control: Discovering and Steering Category-Specific Refusal Directions},
  author  = {Alagharu, others},
  journal = {arXiv preprint arXiv:2603.13359},
  year    = {2026},
  url     = {https://arxiv.org/abs/2603.13359},
  note    = {Closest published analogue to this work. Extracts category-aligned refusal directions in a Llama-3-8B fine-tuned with categorical refusal tokens, then steers per category via a low-rank whitened combination. Our route is unsupervised, on Gemma~3~12B, with capping rather than addition.},
}

@article{zhao2025harmfulness,
  title   = {{LLMs} Encode Harmfulness and Refusal Separately},
  author  = {Zhao, others},
  journal = {arXiv preprint arXiv:2507.11878},
  year    = {2025},
  url     = {https://arxiv.org/abs/2507.11878},
  note    = {Identifies a harmfulness direction distinct from the refusal direction with causal evidence. Supports the premise that refusal is decomposable.},
}

@article{coalson2026failclosed,
  title   = {Fail-Closed Alignment for Large Language Models},
  author  = {Coalson, others},
  journal = {arXiv preprint arXiv:2602.16977},
  year    = {2026},
  url     = {https://arxiv.org/abs/2602.16977},
  note    = {Progressively ablating refusal directions induces multiple causally independent refusal subspaces. Both motivates and constrains domain-selective capping.},
}

@article{maskey2026overrefusal,
  title   = {Over-Refusal and Representation Subspaces: A Mechanistic Analysis of Task-Conditioned Refusal in Aligned {LLM}s},
  author  = {Maskey, others},
  journal = {arXiv preprint arXiv:2603.27518},
  year    = {2026},
  url     = {https://arxiv.org/abs/2603.27518},
  note    = {Distinguishes task-agnostic harmful-refusal directions from task-dependent over-refusal subspaces. Relevant to whether our 6 domains are mutually orthogonal or share a global axis.},
}

